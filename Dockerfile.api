FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY go.mod ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /bin/marketplace-api ./cmd/marketplace-api

FROM alpine:3.21
ENV TZ=Asia/Shanghai
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /bin/marketplace-api /bin/marketplace-api
EXPOSE 8092
ENTRYPOINT ["/bin/marketplace-api"]
